    "%@. Auto-renews until canceled — cancel anytime in Settings." : {
      "comment" : "Footer text at the bottom of the paywall screen, showing the price of the selected paywall plan. The argument is the string “%1$arg%2$arg”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. يتجدد تلقائيًا حتى الإلغاء — يمكنك الإلغاء في أي وقت من الإعدادات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Verlängert sich automatisch bis zur Kündigung — jederzeit in den Einstellungen kündbar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Se renueva automáticamente hasta su cancelación: cancela cuando quieras en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Renouvellement automatique jusqu'à résiliation — annulable à tout moment dans Réglages."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Diperpanjang otomatis sampai dibatalkan — batalkan kapan saja di Pengaturan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@。解約するまで自動更新されます — 設定からいつでも解約できます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Renova automaticamente até o cancelamento — cancele quando quiser em Ajustes."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ต่ออายุอัตโนมัติจนกว่าจะยกเลิก — ยกเลิกได้ทุกเมื่อในการตั้งค่า"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. İptal edilene kadar otomatik yenilenir — Ayarlar'dan istediğin zaman iptal et."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@. Tự động gia hạn cho đến khi hủy — hủy bất cứ lúc nào trong Cài đặt."
          }
        }
      }
    },
