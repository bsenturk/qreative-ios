<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app enables tracking (personalized AdMob ads gated by the ATT prompt). -->
	<key>NSPrivacyTracking</key>
	<true/>

	<!-- GoogleMobileAds.framework's own PrivacyInfo.xcprivacy does not declare
	     NSPrivacyTrackingDomains itself, so Apple's validator requires this app's
	     manifest to list them directly: NSPrivacyTracking = true with an empty
	     domains array fails submission with ITMS-91064. These are AdMob's known
	     ad-serving/tracking domains used for personalized ads. -->
	<key>NSPrivacyTrackingDomains</key>
	<array>
		<string>googlesyndication.com</string>
		<string>googleadservices.com</string>
		<string>doubleclick.net</string>
	</array>

	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- Firebase Analytics: in-app events / screen views. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>

		<!-- Advertising identifier used by AdMob (and analytics). Used for
		     tracking when the user grants ATT. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<true/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeThirdPartyAdvertising</string>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>

		<!-- Subscription state managed through RevenueCat / Apple IAP. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePurchaseHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>

	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- StorageService, AppSettings, HapticManager, LanguageManager,
		     ReviewManager, AppCoordinator read/write the app's own preferences. -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
